#!/usr/bin/env bash
set -eo pipefail

archives=()
paths=()

for arg in "$@"; do
  if [[ -e "$arg" ]]; then
    archives+=("$arg")
  else
    paths+=("$arg")
  fi
done

for arg in "${archives[@]}"; do
  case $arg in
    *.bz2)  bunzip2 "$arg"; continue ;;
    *.gz)   gunzip "$arg";  continue ;;
    *.Z)    uncompress "$arg"; continue ;;
  esac

  dir=$(basename "${arg%.*}")
  mkdir "$dir"

  case $arg in
    *.tar)                       tar xvf "$arg" -C "$dir" "${paths[@]}"  ;;
    *.tar.gz | *.tgz)            tar xvzf "$arg" -C "$dir" "${paths[@]}" ;;
    *.tar.xz | *.xz)             tar xvJf "$arg" -C "$dir" "${paths[@]}" ;;
    *.tar.bz2 | *.tbz | *.tbz2)  tar xvjf "$arg" -C "$dir" "${paths[@]}" ;;
    *.zip)                       unzip "$arg" "${paths[@]}" -d "$dir"    ;;
    *.rar)                       unrar x "$arg" "${paths[@]}" "$dir"/    ;;
    *.7z)                        7z x "$arg" -o"$dir" "${paths[@]}"      ;;
    *)                           echo "Unable to extract '$arg'" >&2; rmdir "$dir"; continue ;;
  esac

  mapfile -t entries < <(find "$dir" -mindepth 1 -maxdepth 1)
  if [[ ${#entries[@]} -eq 1 ]]; then
    mv "${entries[0]}" .
    rmdir "$dir"
  fi
done
