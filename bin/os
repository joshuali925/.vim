#!/usr/bin/env bash
set -eo pipefail

cleanup() {
  [[ -n $pid ]] && kill "$pid"
  exit $?
}

init_security() {
  local pw=$1 tmp_pw='myStrongPassword123_456' hash
  trap cleanup TERM INT EXIT
  OPENSEARCH_INITIAL_ADMIN_PASSWORD=$tmp_pw ./opensearch-tar-install.sh "${@:2}" &
  pid=$!
  while ! curl -fsS -k --max-time 2 "https://admin:$tmp_pw@localhost:9200"; do echo waiting for opensearch..; sleep 2; done
  hash=$(JAVA_HOME="$(mise where java)" OPENSEARCH_JAVA_HOME=$PWD/jdk bash plugins/opensearch-security/tools/hash.sh -p "$pw" 2>/dev/null | tail -1)
  awk -v h="$hash" '
    /^[A-Za-z_][A-Za-z0-9_-]*:[[:space:]]*$/ {
      key=$0; sub(/:.*/,"",key)
      keep = (key=="_meta" || key=="admin" || key=="kibanaserver")
      rotate = (key=="admin")
    }
    keep {
      if (rotate && /^[[:space:]]+hash:/) sub(/hash:.*/, "hash: \"" h "\"")
      print
    }
  ' config/opensearch-security/internal_users.yml > config/opensearch-security/internal_users.yml.tmp \
    && mv config/opensearch-security/internal_users.yml.tmp config/opensearch-security/internal_users.yml
  JAVA_HOME="$(mise where java)" OPENSEARCH_JAVA_HOME=$PWD/jdk bash plugins/opensearch-security/tools/securityadmin.sh \
    -f config/opensearch-security/internal_users.yml -t internalusers -icl -nhnv \
    -cacert config/root-ca.pem -cert config/kirk.pem -key config/kirk-key.pem
  kill "$pid"; wait "$pid" 2>/dev/null || true
  unset pid
}

run() {
  local rest=() start_cmd=start password
  if [[ $OS_DAEMON = 1 ]]; then
    (setsid env OS_DAEMON=0 "$0" run "$@" > ./.daemon-log 2>&1 < /dev/null & echo $! > ./.daemon-pid)
    echo "daemon started process in background, dir: $PWD, logs: ./.daemon-log, pid: ./.daemon-pid" >&2
    return 0
  fi
  while [[ $# -gt 0 ]]; do
    case $1 in
      -h|--help) echo "Usage: ${0##*/} run [-h|--help] [--debug] [--no-sec] [--init-password <password>] [-p|--port <port>] [-b|--bootstrap] [-e|--explore] [passthrough-args...] (OS_DAEMON=1 for background, logs in ./.daemon-log, pid in ./.daemon-pid)" >&2; return 0 ;;
      --debug) export OPENSEARCH_JAVA_OPTS=-agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=5005 ;;
      --no-sec|--nosec) local nosec=1 ;;
      --init-password) password=$2; shift ;;
      -p|--port) local port=$2; shift ;;
      -b|--bootstrap) local bootstrap=1 ;;
      -e|--explore) start_cmd=start:explore rest+=(--workspace.enabled=true) ;;
      --) shift; rest+=("$@"); break ;;
      *) rest+=("$1") ;;
    esac
    shift
  done
  set -- "${rest[@]}"

  if [[ -x bin/opensearch ]]; then
    if [[ -n $port ]]; then set -- -Ehttp.port="$port" "$@"; fi
    if [[ -d plugins/opensearch-security ]] && ! grep -q '^plugins.security.disabled: true' config/opensearch.yml; then
      [[ -n $nosec ]] && exec ./bin/opensearch -Eplugins.security.disabled=true
      if [[ ! -f config/kirk.pem ]]; then
        init_security "${password:-admin}" "$@"
      elif [[ -n $password ]]; then
        echo 'Warning: security already initialized; ignoring password argument' >&2
      fi
    fi
    exec ./bin/opensearch "$@"
  fi

  local opts=(--host 0.0.0.0 --server.maxPayloadBytes=99999999 --opensearch.ignoreVersionMismatch=true --data_source.ssl.verificationMode=none)
  if [[ -n $port ]]; then opts+=(--server.port "$port"); fi
  if [[ -f opensearch_dashboards.json ]]; then cd ../..; fi  # cd up from plugins directory
  # https://github.com/opensearch-project/OpenSearch-Dashboards/blob/c2ac4c8ae102a76df4258e8e871375299b6ad008/src/dev/build/tasks/os_packages/docker_generator/resources/bin/opensearch-dashboards-docker
  if [[ -d plugins/securityDashboards || -d plugins/security-dashboards-plugin ]] && ! grep -q '^opensearch.hosts' config/opensearch_dashboards.yml; then
    opts+=(--opensearch.hosts=https://localhost:9200 --opensearch.username=kibanaserver --opensearch.password=kibanaserver --opensearch.ssl.verificationMode=none --opensearch.requestHeadersWhitelist='["authorization", "securitytenant"]' --opensearch_security.multitenancy.enabled=true --opensearch_security.multitenancy.tenants.preferred='["Private", "Global"]' --opensearch_security.readonly_mode.roles='["kibana_read_only"]' --opensearch_security.cookie.secure=false)
  fi
  if [[ -x bin/opensearch-dashboards ]]; then
    if [[ $start_cmd = start:explore ]]; then
      opts+=(--explore.enabled=true --explore.discoverTraces.enabled=true --explore.discoverMetrics.enabled=true --explore.agentTraces.enabled=true "--uiSettings.overrides['query:enhancements:enabled']=true" "--uiSettings.overrides['home:useNewHomePage']=true" --data_source.enabled=true --opensearchDashboards.branding.useExpandedHeader=false --opensearchDashboards.keyboardShortcuts.enabled=true --csp.warnLegacyBrowsers=false --datasetManagement.enabled=true)
    fi
    exec ./bin/opensearch-dashboards "${opts[@]}" "$@"
  fi
  if [[ -f opensearch_dashboards.d.ts ]]; then
    if [[ -n $bootstrap ]]; then yarn osd bootstrap --single-version=loose || true; fi
    exec env OSD_OPTIMIZER_THEMES="${OSD_OPTIMIZER_THEMES:-v9light,v9dark}" yarn "$start_cmd" --no-base-path "${opts[@]}" "$@"  # --run-examples
  fi
  echo 'Error: Could not find any runnable OpenSearch or OpenSearch Dashboards environment.' >&2
}

optimize() {
  if [[ -f opensearch_dashboards.d.ts ]]; then
    env OSD_OPTIMIZER_THEMES="${OSD_OPTIMIZER_THEMES:-v9light,v9dark}" scripts/use_node scripts/build_opensearch_dashboards_platform_plugins "${@:---no-examples}"
  fi
}

download() {
  if [[ $# -eq 0 || $1 = -h || $1 = --help ]]; then echo "Usage: ${0##*/} download <version> [filter] [-x|--extract]" >&2; return 1; fi
  ver() { awk -F. '{ printf("%d%03d%03d%03d\n", $1,$2,$3,$4); }' <<<"$*"; }

  local version filter='' extract arch=$([[ $(uname -m) =~ (x86_64|amd64) ]] && echo x64 || echo arm64) url selected
  while [[ $# -ne 0 ]]; do
    case $1 in
      *.*.*) version=$1; shift ;;
      -x|--extract) extract=1; shift ;;
      *) filter+=" $1"; shift ;;
    esac
  done
  local core=('opensearch' 'opensearch-dashboards') es=('elasticsearch' 'kibana') opensearch_plugin=('opensearch-security' 'opensearch-sql' 'opensearch-reports-scheduler' 'opensearch-observability' 'opensearch-job-scheduler' 'opensearch-alerting' 'opensearch-anomaly-detection' 'opensearch-ml' 'opensearch-notifications' 'opensearch-notifications-core' 'opensearch-index-management' 'opensearch-knn' 'opensearch-flow-framework' 'opensearch-skills') docker=('docker')
  local artifacts=("${core[@]}" "${opensearch_plugin[@]}" "${es[@]}" "${docker[@]}")

  selected=$(printf "%s\n" "${artifacts[@]}" | fzf --query="${filter# }" --select-1 --bind='tab:down,btab:up') || return 1
  if [[ ${docker[*]} = *${selected}* ]]; then
    curl -fLO https://opensearch.org/samples/docker-compose.yml
    return $?
  fi
  if [[ ${es[*]} = *${selected}* ]]; then
    [[ $arch = x64 ]] && arch=x86_64 || arch=aarch64
    url="https://artifacts.elastic.co/downloads/$selected/$selected-oss-$version-linux-$arch.tar.gz"
  elif [[ ${core[*]} = *${selected}* ]]; then
    if [[ $(ver "$version") -gt $(ver "$(curl -fsSL https://opensearch.org/downloads/ | rg -o 'Version:</strong> ([\d.]+)' -r '$1')") ]]; then
      url="https://ci.opensearch.org/ci/dbc/distribution-build-$selected/$version/latest/linux/$arch/tar/dist/$selected/$selected-$version-linux-$arch.tar.gz"
      printf "\033[0;36m%s\033[0m\n" "Manifest: https://ci.opensearch.org/ci/dbc/distribution-build-$selected/$version/latest/linux/$arch/tar/dist/$selected/manifest.yml" >&2
    else
      url="https://artifacts.opensearch.org/releases/bundle/$selected/$version/$selected-$version-linux-$arch.tar.gz"
    fi
  elif [[ ${opensearch_plugin[*]} = *${selected}* ]]; then
    if [[ $(ver "$version") -ge $(ver 1.3.2) ]]; then  # url changed after 1.3.2
      url="https://ci.opensearch.org/ci/dbc/distribution-build-opensearch/$version/latest/linux/$arch/tar/builds/opensearch/plugins/$selected-$version.0.zip"
    else
      url="https://ci.opensearch.org/ci/dbc/distribution-build-opensearch/$version/latest/linux/$arch/builds/opensearch/plugins/$selected-$version.0.zip"
    fi
  fi

  printf "\033[0;36m%s\033[0m\n" "Downloading from: $url" >&2
  if [[ -n $extract ]] && [[ $url = *.tar.gz ]]; then curl -fL "$url" | tar xz; else curl -fLO "$url"; fi
}

get_endpoint() {
  if [[ -n $endpoint ]]; then echo "${endpoint%%/}"
  elif curl -fsSL localhost:9200 > /dev/null 2>&1; then echo http://localhost:9200
  else echo https://admin:admin@localhost:9200; fi
}

request() {
  local args=(-X "${1^^}") path="/${2##/}"
  if [[ $3 = \{*\} ]]; then args+=(-H 'Content-Type: application/json' -d "$3"); shift; fi
  curl -s -k "${args[@]}" "$(get_endpoint)$path" "${@:3}"
}

query() {
  request post "/_plugins/_$1" "$(jq --compact-output -n --arg query "${*:2}" '$ARGS.named')" | jq -C | less -RiMXF
}

sed() {
  sd '("opensearchDashboardsVersion": ").*(",)' '${1}opensearchDashboards${2}' opensearch_dashboards.json
}

flog() {
  request put flog || true; echo
  request put flog/_mapping '{"properties":{"bytes":{"type":"long"},"datetime":{"type":"date","format":"dd/MMM/yyyy:HH:mm:ss Z||strict_date_optional_time||epoch_millis"},"host":{"type":"keyword"},"method":{"type":"keyword"},"protocol":{"type":"keyword"},"referer":{"type":"text","fields":{"keyword":{"type":"keyword","ignore_above":256}}},"request":{"type":"text","fields":{"keyword":{"type":"keyword","ignore_above":256}}},"status":{"type":"keyword"},"user-identifier":{"type":"text","fields":{"keyword":{"type":"keyword","ignore_above":256}}}}}' || true; echo
  while request post flog/_doc "$(command flog -f json -n 1)"; do echo; sleep 1; done
}

main() {
  case $1 in
    run|optimize|download|sed) "$@" ;;
    d) download "${@:2}" ;;
    sql*|ppl*) query "$@" ;;
    get|put|post|delete|GET|PUT|POST|DELETE) request "$@" ;;
    flog) "$@" ;;
    *) echo "Usage: ${0##*/} {run|optimize|d|download|sql|ppl|get|put|post|delete|flog} [args]" >&2; exit 1 ;;
  esac
}

main "$@"
