#!/usr/bin/env bash
source ~/.vim/bin/_install_from_github.sh
run-if-exists "$0" "$@"
detect-env

case $PLATFORM in  # versions: https://www.7-zip.org/download.html
  linux) executable=7zzs ;;
  darwin) executable=7zz ;;
  *) echo "package not found for '${0##*/}' on $PLATFORM $ARCHITECTURE, exiting.." >&2 ; exit 1 ;;
esac

install-from-github 7z ip7z/7zip linux-x64 linux-arm64 mac mac "$executable && mv ~/.local/bin/$executable ~/.local/bin/7z" "$@"
