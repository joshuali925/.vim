{
  "env": {
    "AWS_REGION": "us-west-2",
    "CLAUDE_CODE_ENABLE_AUTO_MODE": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_ENABLE_AWAY_SUMMARY": "0",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_CODE_USE_BEDROCK": "1",
    "DISABLE_BUG_COMMAND": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_TELEMETRY": "1",
    "MCP_TIMEOUT": "120000"
  },
  "includeCoAuthoredBy": false,
  "respondToBashCommands": false,
  "permissions": {
    "defaultMode": "auto"
  },
  "model": "global.anthropic.claude-opus-4-8[1m]",
  "availableModels": [
    "claude-opus-4-6[1m]",
    "claude-opus-4-6",
    "claude-opus-4-7[1m]",
    "claude-opus-4-7",
    "claude-opus-4-8[1m]",
    "claude-opus-4-8",
    "claude-sonnet-4-6",
    "claude-sonnet-4-6[1m]",
    "claude-sonnet-5",
    "claude-fable-5",
    "claude-fable-5[1m]",
    "claude-haiku-4-5"
  ],
  "enforceAvailableModels": true,
  "modelOverrides": {
    "claude-opus-4-6[1m]": "global.anthropic.claude-opus-4-6-v1[1m]",
    "claude-opus-4-6": "global.anthropic.claude-opus-4-6-v1",
    "claude-opus-4-7[1m]": "global.anthropic.claude-opus-4-7[1m]",
    "claude-opus-4-7": "global.anthropic.claude-opus-4-7",
    "claude-opus-4-8[1m]": "global.anthropic.claude-opus-4-8[1m]",
    "claude-opus-4-8": "global.anthropic.claude-opus-4-8",
    "claude-sonnet-4-6": "global.anthropic.claude-sonnet-4-6",
    "claude-sonnet-4-6[1m]": "global.anthropic.claude-sonnet-4-6[1m]",
    "claude-sonnet-5": "global.anthropic.claude-sonnet-5",
    "claude-fable-5": "global.anthropic.claude-fable-5[1m]",
    "claude-fable-5[1m]": "global.anthropic.claude-fable-5[1m]",
    "claude-haiku-4-5": "global.anthropic.claude-haiku-4-5-20251001-v1:0"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.vim/config/claude/osc9-notify",
            "async": true
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.vim/config/claude/osc9-notify",
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "idle_prompt|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "~/.vim/config/claude/osc9-notify",
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.vim/config/claude/osc9-notify",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "ccstatusline",
    "padding": 0
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "frontend-slides@frontend-slides": false,
    "skill-creator@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "ui-ux-pro-max@ui-ux-pro-max-skill": false,
    "interface-design@interface-design": false,
    "impeccable@impeccable": false
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "frontend-slides": {
      "source": {
        "source": "github",
        "repo": "zarazhangrui/frontend-slides"
      }
    },
    "ui-ux-pro-max-skill": {
      "source": {
        "source": "github",
        "repo": "nextlevelbuilder/ui-ux-pro-max-skill"
      }
    },
    "interface-design": {
      "source": {
        "source": "github",
        "repo": "Dammyjay93/interface-design"
      }
    },
    "impeccable": {
      "source": {
        "source": "github",
        "repo": "pbakaus/impeccable"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "theme": "auto",
  "verbose": true
}